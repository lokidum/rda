---
// The signature scroll-driven road spine and the little RAMS sedan.
// Markup + styles only. The GSAP MotionPath wiring lives in Motion.astro so
// GSAP registers once and ScrollTrigger coordinates all effects together.
---

<div id="roadwrap" aria-hidden="true">
  <svg id="roadsvg" preserveAspectRatio="none">
    <path id="roadpath" d=""></path>
    <path id="roaddash" d=""></path>
  </svg>
  <svg id="car" width="64" height="128" viewBox="0 0 140 280" style="position:absolute;top:0;left:0;opacity:0" aria-hidden="true">
    <defs>
      <linearGradient id="sedanBody" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#FFFFFF"></stop>
        <stop offset=".5" stop-color="#EEF0F2"></stop>
        <stop offset="1" stop-color="#D5DADF"></stop>
      </linearGradient>
      <linearGradient id="sedanGlass" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#41505C"></stop>
        <stop offset="1" stop-color="#1B232B"></stop>
      </linearGradient>
      <filter id="sedanSoft" x="-40%" y="-40%" width="180%" height="180%"><feGaussianBlur stdDeviation="7"></feGaussianBlur></filter>
    </defs>
    <ellipse cx="70" cy="138" rx="54" ry="116" fill="rgba(20,12,8,.28)" filter="url(#sedanSoft)"></ellipse>
    <rect x="10" y="52" width="13" height="36" rx="6" fill="#15100C"></rect>
    <rect x="117" y="52" width="13" height="36" rx="6" fill="#15100C"></rect>
    <rect x="10" y="186" width="13" height="36" rx="6" fill="#15100C"></rect>
    <rect x="117" y="186" width="13" height="36" rx="6" fill="#15100C"></rect>
    <path d="M70 10 C99 10 112 27 114 54 L116 196 C116 233 100 254 70 254 C40 254 24 233 24 196 L26 54 C28 27 41 10 70 10 Z" fill="url(#sedanBody)" stroke="#B9BFC6" stroke-width="1.5"></path>
    <path d="M34 62 C50 52 90 52 106 62" fill="none" stroke="rgba(20,12,8,.12)" stroke-width="1.6"></path>
    <path d="M37 26 C45 17 56 13 65 13 L65 23 C56 23 47 26 41 31 Z" fill="#DBE7EF"></path>
    <path d="M103 26 C95 17 84 13 75 13 L75 23 C84 23 93 26 99 31 Z" fill="#DBE7EF"></path>
    <path d="M38 80 C53 67 87 67 102 80 L96 110 C80 102 60 102 44 110 Z" fill="url(#sedanGlass)"></path>
    <rect x="42" y="106" width="56" height="62" rx="13" fill="#F7F9FA" stroke="#C6CCD2" stroke-width="1"></rect>
    <path d="M44 170 C60 178 80 178 96 170 L102 196 C88 209 52 209 38 196 Z" fill="url(#sedanGlass)"></path>
    <path d="M36 216 C56 224 84 224 104 216" fill="none" stroke="rgba(20,12,8,.14)" stroke-width="1.6"></path>
    <rect x="13" y="86" width="15" height="11" rx="5" fill="#DDE1E5" stroke="#B9BFC6" stroke-width="1"></rect>
    <rect x="112" y="86" width="15" height="11" rx="5" fill="#DDE1E5" stroke="#B9BFC6" stroke-width="1"></rect>
    <rect x="31" y="238" width="25" height="8" rx="4" fill="#C2261B"></rect>
    <rect x="84" y="238" width="25" height="8" rx="4" fill="#C2261B"></rect>
    <path d="M70 172 l5 12 h-10 Z" fill="#9AA2AA"></path>
    <rect x="44" y="118" width="52" height="34" rx="9" fill="#F2CE16" stroke="#211309" stroke-width="2.5"></rect>
    <text x="70" y="141" text-anchor="middle" font-size="15" font-weight="900" font-family="Arial" letter-spacing="1" fill="#211309">RAMS</text>
  </svg>
</div>

<style is:global>
  #roadwrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
    z-index: 2;
    overflow: visible;
  }
  #roadsvg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  #roadpath {
    fill: none;
    stroke: var(--ink);
    stroke-width: 22;
    stroke-linecap: round;
    opacity: 0.07;
  }
  #roaddash {
    fill: none;
    stroke: var(--maroon);
    stroke-width: 2.5;
    stroke-dasharray: 14 18;
    opacity: 0.42;
  }
  #car {
    will-change: transform;
    filter: drop-shadow(0 10px 14px rgba(33, 19, 9, 0.3));
  }
  @media (max-width: 920px) {
    #roadpath {
      stroke-width: 16;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #roadwrap {
      display: none;
    }
  }
</style>
