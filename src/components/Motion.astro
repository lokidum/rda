---
// Central GSAP motion island. Bundled locally (no CDN). Registers GSAP once so
// ScrollTrigger coordinates every scroll-driven effect, and the road + sedan
// ride a MotionPath scrubbed to page scroll. Everything no-ops under
// prefers-reduced-motion, falling back to static final states.
---

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fine = matchMedia('(pointer: fine)').matches;

  if (reduce) {
    // Reduced motion: reveal everything, hide the travelling car.
    document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
      el.style.opacity = '1';
      el.style.transform = 'none';
    });
    document.querySelectorAll<HTMLElement>('#hero h1 .word > span').forEach((s) => (s.style.transform = 'none'));
    document.querySelectorAll('#manifesto .w').forEach((w) => w.classList.add('lit'));
    document.querySelectorAll('.label').forEach((l) => l.classList.add('drawn'));
    document.querySelectorAll('[data-count]').forEach((el) => {
      el.textContent = String((el as HTMLElement).dataset.count);
    });
    const car = document.getElementById('car');
    if (car) car.style.display = 'none';
  } else {
    gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

    /* hero entrance */
    gsap.to('#hero h1 .word > span', { y: 0, duration: 1.1, stagger: 0.08, ease: 'power4.out', delay: 0.2 });
    gsap.from('#hero .hero-eyebrow, #hero .lede, #hero .hero-ctas, .hero-foot', {
      opacity: 0,
      y: 24,
      duration: 1,
      stagger: 0.1,
      ease: 'power3.out',
      delay: 0.55,
    });
    gsap.fromTo('#hero .hero-media', { scale: 1.08 }, { scale: 1, duration: 2.2, ease: 'power2.out' });
    gsap.to('#hero .hero-media', {
      yPercent: 14,
      ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true },
    });
    gsap.to('#heroWheel', {
      rotation: 80,
      ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true },
    });

    /* generic reveals + the eyebrow rule drawing in */
    gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
      gsap.to(el, { opacity: 1, y: 0, duration: 1, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 88%' } });
    });
    gsap.utils.toArray<HTMLElement>('.label').forEach((el) => {
      ScrollTrigger.create({ trigger: el, start: 'top 90%', onEnter: () => el.classList.add('drawn') });
    });

    /* manifesto word-by-word light up (words pre-rendered server-side) */
    const statement = document.getElementById('statement');
    if (statement) {
      const words = statement.querySelectorAll('.w');
      ScrollTrigger.create({
        trigger: statement,
        start: 'top 80%',
        end: 'bottom 48%',
        scrub: 0.4,
        onUpdate: (self) => {
          const n = Math.floor(self.progress * words.length);
          words.forEach((w, i) => w.classList.toggle('lit', i <= n));
        },
      });
    }

    /* parallax framed images (not the hero media, handled above) */
    gsap.utils.toArray<HTMLElement>('.ph.parallax').forEach((ph) => {
      if (ph.classList.contains('hero-media')) return;
      const img = ph.querySelector('img');
      if (!img) return; // placeholder only, nothing to move
      gsap.fromTo(
        img,
        { yPercent: -8, scale: 1.12 },
        { yPercent: 8, ease: 'none', scrollTrigger: { trigger: ph, start: 'top bottom', end: 'bottom top', scrub: true } }
      );
    });

    /* experience steps + photo crossfade */
    const layers = document.querySelectorAll('#expPh .layer');
    const badge = document.getElementById('expBadge');
    gsap.utils.toArray<HTMLElement>('.exp-step').forEach((stp) => {
      ScrollTrigger.create({
        trigger: stp,
        start: 'top 62%',
        end: 'bottom 62%',
        onToggle: (self) => {
          if (!self.isActive) return;
          document.querySelectorAll('.exp-step').forEach((x) => x.classList.toggle('active', x === stp));
          const img = Number(stp.dataset.img ?? 0);
          layers.forEach((l, li) => l.classList.toggle('active', li === img));
          if (badge && stp.dataset.badge) badge.innerHTML = stp.dataset.badge;
        },
      });
    });

    /* count-up stats */
    gsap.utils.toArray<HTMLElement>('[data-count]').forEach((el) => {
      const target = Number(el.dataset.count);
      const obj = { v: 0 };
      gsap.to(obj, {
        v: target,
        duration: 1.8,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%' },
        onUpdate: () => (el.textContent = String(Math.round(obj.v))),
      });
    });

    /* fine-pointer flourishes: magnetic buttons + gentle 3D tilt */
    if (fine) {
      document.querySelectorAll<HTMLElement>('.btn').forEach((b) => {
        b.addEventListener('pointermove', (e) => {
          const r = b.getBoundingClientRect();
          gsap.to(b, { x: (e.clientX - r.left - r.width / 2) * 0.18, y: (e.clientY - r.top - r.height / 2) * 0.3, duration: 0.4, ease: 'power2.out' });
        });
        b.addEventListener('pointerleave', () => gsap.to(b, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1,.5)' }));
      });
      gsap.utils.toArray<HTMLElement>('.svc, .exp-visual .ph').forEach((card) => {
        card.style.transformPerspective = '900px';
        card.addEventListener('pointermove', (e) => {
          const r = card.getBoundingClientRect();
          const rx = ((e.clientY - r.top) / r.height - 0.5) * -4;
          const ry = ((e.clientX - r.left) / r.width - 0.5) * 5;
          gsap.to(card, { rotationX: rx, rotationY: ry, duration: 0.5, ease: 'power2.out' });
        });
        card.addEventListener('pointerleave', () => gsap.to(card, { rotationX: 0, rotationY: 0, duration: 0.7, ease: 'power3.out' }));
      });
    }

    /* ---------- the road spine + travelling sedan ---------- */
    function buildRoad() {
      const svg = document.getElementById('roadsvg');
      const wrap = document.getElementById('roadwrap');
      const roadpath = document.getElementById('roadpath');
      const roaddash = document.getElementById('roaddash');
      const hero = document.getElementById('hero');
      if (!svg || !wrap || !roadpath || !roaddash || !hero) return;

      const docH = document.documentElement.scrollHeight;
      const W = window.innerWidth;
      wrap.style.height = docH + 'px';
      svg.setAttribute('viewBox', `0 0 ${W} ${docH}`);
      svg.setAttribute('width', String(W));
      svg.setAttribute('height', String(docH));

      const cx = W / 2;
      const amp = W < 700 ? W * 0.3 : Math.min(W * 0.36, 460);
      const startY = hero.offsetTop + hero.offsetHeight + 140;
      const endY = docH - window.innerHeight * 0.62;
      const span = Math.max(endY - startY, 1200);
      const waves = Math.max(4, Math.round(span / 1050));
      let d = `M ${cx} ${startY}`;
      for (let i = 0; i < waves; i++) {
        const y0 = startY + span * (i / waves);
        const y1 = startY + span * ((i + 1) / waves);
        const side = i % 2 === 0 ? 1 : -1;
        d += ` C ${cx + amp * side} ${y0 + (y1 - y0) * 0.3}, ${cx + amp * side} ${y0 + (y1 - y0) * 0.7}, ${cx} ${y1}`;
      }
      roadpath.setAttribute('d', d);
      roaddash.setAttribute('d', d);

      const carScale = W < 700 ? 0.72 : 1;
      gsap.killTweensOf('#car');
      gsap.set('#car', { opacity: 1, scale: carScale, transformOrigin: '50% 50%' });
      gsap.to('#car', {
        ease: 'none',
        motionPath: { path: '#roadpath', align: '#roadpath', alignOrigin: [0.5, 0.5], autoRotate: 90 },
        scrollTrigger: { trigger: document.body, start: 'top top', end: 'max', scrub: 0.8, invalidateOnRefresh: true },
      });
    }
    buildRoad();

    let rT: number;
    addEventListener('resize', () => {
      clearTimeout(rT);
      rT = window.setTimeout(() => {
        buildRoad();
        ScrollTrigger.refresh();
      }, 300);
    });
    addEventListener('load', () => {
      setTimeout(() => {
        buildRoad();
        ScrollTrigger.refresh();
      }, 700);
    });
  }
</script>
