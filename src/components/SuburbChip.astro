---
import { areas, waLink } from '../data/content';

interface Props {
  suburb?: string;
  generic?: boolean;
}
const { suburb, generic = false } = Astro.props;

const label = generic ? '+ yours, just ask' : suburb!;
const message = generic ? areas.genericMessage : areas.chipMessage(suburb!);
---

<a class="chip" href={waLink(message)} target="_blank" rel="noopener">{label}</a>

<style>
  .chip {
    border: 1px solid var(--hair-strong);
    background: var(--cream-2);
    border-radius: 999px;
    padding: 9px 18px;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--ink);
    cursor: pointer;
    box-shadow: var(--sh-sm);
    scale: 1;
    transition: background 0.3s var(--ease), color 0.3s, border-color 0.3s, box-shadow 0.3s, scale 0.2s var(--ease);
  }
  .chip:hover {
    background: var(--maroon);
    color: var(--cream-2);
    border-color: var(--maroon);
    box-shadow: var(--glow-maroon);
  }
  .chip:active {
    scale: 0.94;
  }
</style>
